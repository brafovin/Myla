{
  "name": "cokomi",
  "version": "0.1.0",
  "private": true,
  "description": "CoKomi – Sprach- und Kulturaustausch-App für Erwachsene (18+).",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm run dev --workspace=@myla/backend",
    "dev:frontend": "npm run dev --workspace=@myla/frontend",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20"
  }
}
